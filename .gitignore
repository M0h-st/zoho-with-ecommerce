# Ignore everything in this Local WordPress site by default.
*

# Repo metadata
!.gitignore
!README.md
!LICENSE
!ZOHO-INTEGRATION.md

# Deluge integration (primary deliverable)
!deluge/
!deluge/**

# Integration plugin (optional WordPress path)
!app/
!app/public/
!app/public/wp-content/
!app/public/wp-content/plugins/
!app/public/wp-content/plugins/woocommerce-zoho-crm/
!app/public/wp-content/plugins/woocommerce-zoho-crm/**

# CLI helper
!integration/
!integration/**

# Never commit secrets or local overrides
**/local-config.php
.env
.env.*
*.log
logs/
app/public/wp-config.php
app/public/wp-content/uploads/
app/public/local-*.php

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
